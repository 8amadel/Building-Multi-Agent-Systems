PROJECT_ID=
REGION_ID=
GEMINI_MODEL=gemini-3.1-pro-preview
### Base Directory -- Location of the horizon directory. 
### For example, if the location is /home/myuser/mas then set BASE_DIR to /home/myuser
BASE_DIR=
####################################################################################################################
#### AlloyDB cluster, instance and database names - at least 4 characters
### The script will create a new cluster, instance and database with these names
NETWORK_NAME=alloydbnetwork
ALLOYDB_CLUSTER_NAME=mascluster
ALLOYDB_INSTANCE_NAME=masinstance
ALLOYDB_DATABASE_NAME=masdatabase
####################################################################################################################
